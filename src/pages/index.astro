---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="G M AL MAMUN | AI & Intelligent Transportation Researcher"
  description="Personal academic website focused on autonomous vehicles, AI in transportation, and intelligent transportation systems."
>

<main class="min-h-screen bg-slate-50 text-slate-800">

  <!-- HERO -->
  <section class="max-w-7xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-12 items-center">

    <!-- LEFT -->
    <div>

      <p class="text-blue-600 font-semibold tracking-widest uppercase">
        AI & Intelligent Transportation Researcher
      </p>

      <h1 class="text-5xl md:text-6xl font-extrabold mt-4 text-slate-900">
        G M AL MAMUN
      </h1>

      <p class="text-xl text-blue-700 font-semibold mt-4">
        Preparing for PhD in Intelligent Transportation Systems
      </p>

      <p class="mt-8 text-lg leading-8 text-slate-600">
        I focus on Autonomous Vehicle Safety, Autonomous Driving Behavior,
        Artificial Intelligence in Transportation, and Intelligent Transportation Systems.
        My research aims to improve safety, efficiency, and intelligence in future mobility systems.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">

        <a href="#research"
          class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
          Research
        </a>

        <a href="#projects"
          class="border border-blue-600 text-blue-600 px-6 py-3 rounded-lg hover:bg-blue-600 hover:text-white transition">
          Projects
        </a>

        <a href="/cv"
          class="border border-slate-400 text-slate-700 px-6 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition">
          CV
        </a>

      </div>

    </div>

    <!-- RIGHT IMAGE -->
    <div class="flex justify-center">

      <img
        src="/profile.jpg"
        alt="G M AL MAMUN"
        class="w-80 h-80 md:w-96 md:h-96 object-cover rounded-full shadow-2xl border-8 border-white"
      />

    </div>

  </section>

  <!-- RESEARCH -->
  <section id="research" class="bg-white py-24">

    <div class="max-w-6xl mx-auto px-6">

      <h2 class="text-4xl font-bold text-center mb-14">
        Research Interests
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-slate-100 p-6 rounded-xl hover:shadow-lg transition">
          🚗 <h3 class="mt-4 font-semibold">Autonomous Vehicle Safety</h3>
        </div>

        <div class="bg-slate-100 p-6 rounded-xl hover:shadow-lg transition">
          🤖 <h3 class="mt-4 font-semibold">AI in Transportation</h3>
        </div>

        <div class="bg-slate-100 p-6 rounded-xl hover:shadow-lg transition">
          🚦 <h3 class="mt-4 font-semibold">Intelligent Transportation Systems</h3>
        </div>

        <div class="bg-slate-100 p-6 rounded-xl hover:shadow-lg transition">
          📡 <h3 class="mt-4 font-semibold">Cooperative Perception</h3>
        </div>

      </div>

    </div>

  </section>

  <!-- PROJECTS -->
  <section id="projects" class="py-24">

    <div class="max-w-6xl mx-auto px-6">

      <h2 class="text-4xl font-bold text-center mb-14">
        Featured Projects
      </h2>

      <div class="grid md:grid-cols-2 gap-8">

        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition">
          <h3 class="text-2xl font-bold">🚗 CARLA Simulation Research</h3>
          <p class="mt-4 text-slate-600">
            Multi-agent autonomous driving simulation for safety-critical scenarios and cooperative perception.
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition">
          <h3 class="text-2xl font-bold">🚦 SUMO Traffic Simulation</h3>
          <p class="mt-4 text-slate-600">
            Traffic flow modeling and AI-based congestion prediction using SUMO.
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition">
          <h3 class="text-2xl font-bold">🤖 Reinforcement Learning for AV</h3>
          <p class="mt-4 text-slate-600">
            Deep reinforcement learning for autonomous decision-making in dynamic environments.
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition">
          <h3 class="text-2xl font-bold">📡 Cooperative Perception (GNN)</h3>
          <p class="mt-4 text-slate-600">
            Graph Neural Networks for improving perception in connected autonomous vehicles.
          </p>
        </div>

      </div>

    </div>

  </section>

  <!-- GET IN TOUCH (CLEAN MINIMAL VERSION) -->
  <section class="bg-white border-t border-slate-200 py-16 mt-20">

    <div class="max-w-4xl mx-auto text-center px-6">

      <h2 class="text-3xl md:text-4xl font-bold text-slate-900">
        Get in Touch for Collaboration
      </h2>

      <p class="mt-6 text-lg text-slate-600 leading-8">
        Open to PhD collaboration, research discussions, and joint publications in
        Autonomous Vehicles, AI in Transportation, and Intelligent Transportation Systems.
      </p>

    </div>

  </section>

</main>

</Layout>