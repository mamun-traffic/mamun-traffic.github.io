---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Publications | G M AL MAMUN"
  description="Research publications of G M AL MAMUN in AI, autonomous vehicles, and intelligent transportation systems."
>

<main class="min-h-screen bg-slate-50 text-slate-800 py-24">

  <div class="max-w-5xl mx-auto px-6">

    <h1 class="text-4xl font-bold text-center mb-12">
      Publications
    </h1>

    <!-- Journal Papers -->
    <section class="mb-16">

      <h2 class="text-2xl font-semibold mb-6 text-blue-700">
        Journal Papers
      </h2>

      <div class="space-y-6">

        <div class="bg-white p-6 rounded-xl shadow">
          <p class="font-semibold">
            Title of Your Journal Paper (Add later)
          </p>
          <p class="text-slate-600 mt-2">
            Journal Name, Year
          </p>
          <p class="text-sm text-slate-500 mt-2">
            Keywords: Autonomous Vehicles, AI, ITS
          </p>
        </div>

      </div>

    </section>

    <!-- Conference Papers -->
    <section class="mb-16">

      <h2 class="text-2xl font-semibold mb-6 text-blue-700">
        Conference Papers
      </h2>

      <div class="space-y-6">

        <div class="bg-white p-6 rounded-xl shadow">
          <p class="font-semibold">
            Title of Your Conference Paper (Add later)
          </p>
          <p class="text-slate-600 mt-2">
            Conference Name, Year
          </p>
          <p class="text-sm text-slate-500 mt-2">
            Keywords: CARLA, SUMO, Reinforcement Learning
          </p>
        </div>

      </div>

    </section>

    <!-- Future Work -->
    <section>

      <h2 class="text-2xl font-semibold mb-6 text-blue-700">
        Ongoing Research
      </h2>

      <div class="bg-white p-6 rounded-xl shadow">

        <p class="font-semibold">
          Multi-Agent Reinforcement Learning for Autonomous Vehicles
        </p>

        <p class="text-slate-600 mt-2">
          Under development — focusing on cooperative driving in mixed traffic environments.
        </p>

      </div>

    </section>

  </div>

</main>

</Layout>