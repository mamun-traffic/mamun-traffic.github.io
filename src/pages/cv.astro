---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="CV | G M AL MAMUN"
  description="Curriculum Vitae of G M AL MAMUN"
>

<main class="min-h-screen bg-slate-50 text-slate-800">

  <!-- HEADER -->
  <section class="max-w-4xl mx-auto px-6 py-20 text-center">

    <h1 class="text-5xl font-extrabold text-slate-900">
      Curriculum Vitae
    </h1>

    <p class="mt-4 text-slate-600">
      Download or view my academic CV below.
    </p>

    <!-- DOWNLOAD BUTTON -->
    <div class="mt-8">
      <a
        href="/cv.pdf"
        target="_blank"
        class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition"
      >
        Download CV (PDF)
      </a>
    </div>

  </section>

  <!-- PREVIEW SECTION -->
  <section class="max-w-5xl mx-auto px-6 pb-20">

    <div class="bg-white shadow-lg rounded-xl p-6">

      <p class="text-center text-slate-500">
        If PDF preview does not show, use the download button above.
      </p>

      <!-- Embedded PDF -->
      <iframe
        src="/cv.pdf"
        class="w-full h-[800px] mt-6 rounded-lg border"
      ></iframe>

    </div>

  </section>

</main>

</Layout>